---
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} Ethan K Kuntz</span>
	<ul class="footer-links">
		<li><a href="https://x.com/KanizsaBoundary" target="_blank" rel="noopener">Twitter</a></li>
		<li><a href="https://substack.com/@mindthemanifold" target="_blank" rel="noopener">Substack</a></li>
	</ul>
</footer>

<style>
	footer {
		padding: 2rem 3rem;
		border-top: 1px solid var(--rule);
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	footer span {
		font-size: 0.8rem;
		color: var(--fg-muted);
		letter-spacing: 0.02em;
	}
	.footer-links {
		display: flex;
		gap: 1.5rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-links a {
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		color: var(--fg-muted);
		text-decoration: none;
		transition: color 0.3s;
	}
	.footer-links a:hover { color: var(--accent); }
	@media (max-width: 600px) {
		footer {
			padding: 1.5rem;
			flex-direction: column;
			gap: 0.5rem;
		}
	}
</style>
